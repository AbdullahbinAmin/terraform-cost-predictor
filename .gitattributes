# Handle line endings automatically
* text=auto

# Force Unix line endings for Python and YAML files
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.txt   text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.whl   binary
